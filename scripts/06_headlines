#!/usr/bin/env python3
# -*- coding: utf-8 -*-

"""
SCRIPT 3 – ÜBERSCHRIFTEN-ERKENNUNG (HEURISTISCH)

Regeln:
- Fettgedruckte Einzelzeile (**Text**), gefolgt von Leerzeile → ## Text
- Fettgedruckte Zeile + danach Trenner / Absatz → ## Text
- Zeilen in VERSALIEN oder Title-Case ohne Satzpunkt → mögliche Überschrift
- Keine automatische Erhöhung der Hierarchie
- Originaltext bleibt unverändert, nur Markup
- Zitate zu blockquotes
  - italic string zu bloquote headder (**_Text_** → > ### Text) entferne im Block " wenn vorhanden
  - italic Text zu blockquote (_Text → > Text) entferne im Block " und _ wenn vorhanden
"""

import re
from pathlib import Path

# =========================
# KONFIGURATION
# =========================
TARGET_DIR = Path("../artikel")

# =========================
# REGEX
# =========================
BOLD_LINE_RE = re.compile(r"^\*\*(.+?)\*\*\s*$")
SEPARATOR_RE = re.compile(r"^[-_]{3,}\s*$")
HEADER_ALREADY_RE = re.compile(r"^#{1,6}\s")

# =========================
# HEURISTIKEN
# =========================
def is_all_caps(line: str) -> bool:
    letters = [c for c in line if c.isalpha()]
    return bool(letters) and all(c.isupper() for c in letters)

def is_title_case(line: str) -> bool:
    words = line.split()
    return (
        len(words) >= 2
        and all(w[:1].isupper() for w in words if w[:1].isalpha())
    )

def looks_like_heading(line: str) -> bool:
    line = line.strip()
    if not line:
        return False
    if line.endswith((".", ":", ";", "!", "?")):
        return False
    if HEADER_ALREADY_RE.match(line):
        return False
    return is_all_caps(line) or is_title_case(line)

# =========================
# PROCESSING
# =========================
def process_lines(lines: list[str]) -> list[str]:
    out = []
    i = 0

    while i < len(lines):
        line = lines[i]
        stripped = line.strip()

        # ---------------------------------
        # Regel 1 + 2: **Text**
        # ---------------------------------
        m = BOLD_LINE_RE.match(stripped)
        if m and not HEADER_ALREADY_RE.match(stripped):
            next_line = lines[i + 1] if i + 1 < len(lines) else ""
            next_stripped = next_line.strip()

            if next_stripped == "" or SEPARATOR_RE.match(next_stripped):
                out.append(f"## {m.group(1)}\n")
                i += 1
                continue

        # ---------------------------------
        # Regel 3: CAPS / Title Case
        # ---------------------------------
        if looks_like_heading(stripped):
            next_line = lines[i + 1] if i + 1 < len(lines) else ""
            if next_line.strip() == "":
                out.append(f"## {stripped}\n")
                i += 1
                continue

        # ---------------------------------
        # Default: unverändert
        # ---------------------------------
        out.append(line)
        i += 1

    return out

def process_text(text: str) -> str:
    lines = text.splitlines(keepends=True)
    new_lines = process_lines(lines)
    return "".join(new_lines)

# =========================
# MAIN
# =========================
def main():
    if not TARGET_DIR.exists():
        raise SystemExit(f"Target directory not found: {TARGET_DIR}")

    files = list(TARGET_DIR.rglob("*.md"))

    for path in files:
        original = path.read_text(encoding="utf-8", errors="replace")
        cleaned = process_text(original)

        if cleaned != original:
            path.write_text(cleaned, encoding="utf-8")
            print(f"✔ headings detected: {path}")
        else:
            print(f"– unchanged: {path}")

    print(f"\nDone. Processed {len(files)} markdown files.")

if __name__ == "__main__":
    main()
